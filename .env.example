# Optional: enables AI reranking for top matched jobs
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_RERANK_TOP_N=3
OPENAI_TIMEOUT_MS=8000

# Required for demo login accounts
DEMO_ADMIN_PASSWORD=replace_with_recruiter_demo_password
DEMO_CANDIDATE_PASSWORD=replace_with_candidate_demo_password
